	<item>
		<title>About Us</title>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[<!-- wp:group {"style":{"spacing":{"padding":{"top":"60px","bottom":"60px"}}}} -->
		<div class="wp-block-group" style="padding-top:60px;padding-bottom:60px"><!-- wp:heading {"style":{"color":{"text":"#c9a96e"}}} -->
		<h2 class="wp-block-heading" style="color:#c9a96e">Meet the Agency</h2>
		<!-- /wp:heading -->

		<!-- wp:paragraph {"style":{"color":{"text":"#f5f5f5"}}} -->
		<p style="color:#f5f5f5">Opulentia Agency is a collective of strategists, designers, and engineers who believe great work comes from collaboration. Since 2018, we've partnered with startups and Fortune 500 companies alike to create digital experiences that matter.</p>
		<!-- /wp:paragraph -->

		<!-- wp:paragraph {"style":{"color":{"text":"#999999"}}} -->
		<p style="color:#999999">Our team of 30+ experts spans brand strategy, UX/UI design, development, and performance marketing. We're headquartered in San Francisco with satellites in London and Singapore.</p>
		<!-- /wp:paragraph --></div>
		<!-- /wp:group -->]]></content:encoded>
