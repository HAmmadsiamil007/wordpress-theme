		"op_header_text_color": "#ffffff",
		"op_footer_bg": "#111111",
		"op_footer_text_color": "#f5f5f5",
		"op_sidebar_position": "right",
		"op_blog_excerpt_length": 45,
		"op_blog_read_more_text": "Read More",
		"op_show_breadcrumbs": false,
		"op_breadcrumb_separator": "/",
		"op_scroll_to_top": true,
		"op_dark_mode_toggle": false,
