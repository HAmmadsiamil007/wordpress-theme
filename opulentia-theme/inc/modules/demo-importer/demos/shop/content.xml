	<item>
		<title>New Arrivals: Spring Collection 2026</title>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[<!-- wp:paragraph -->
		<p>Our Spring 2026 collection has arrived. This season we're exploring clean lines, rich textures, and a palette inspired by the Mediterranean coast.</p>
		<!-- /wp:paragraph -->

		<!-- wp:paragraph -->
		<p>Highlights include hand-stitched leather accessories, lightweight linen tailoring, and our new signature fragrance line.</p>
		<!-- /wp:paragraph -->]]></content:encoded>
