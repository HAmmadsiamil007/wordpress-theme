	<item>
		<title>About Our Brand</title>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[<!-- wp:group {"style":{"spacing":{"padding":{"top":"60px","bottom":"60px"}}}} -->
		<div class="wp-block-group" style="padding-top:60px;padding-bottom:60px"><!-- wp:heading {"style":{"color":{"text":"#c9a96e"}}} -->
		<h2 class="wp-block-heading" style="color:#c9a96e">Our Story</h2>
		<!-- /wp:heading -->

		<!-- wp:paragraph {"style":{"color":{"text":"#f5f5f5"}}} -->
		<p style="color:#f5f5f5">Opulentia began with a simple belief: everyday objects should be extraordinary. We partner with master artisans from around the world to bring you products that are made to last and designed to impress.</p>
		<!-- /wp:paragraph -->

		<!-- wp:paragraph {"style":{"color":{"text":"#999999"}}} -->
		<p style="color:#999999">From Italian leather goods to Japanese denim, every item in our collection meets the highest standards of quality and ethical production.</p>
		<!-- /wp:paragraph --></div>
		<!-- /wp:group -->]]></content:encoded>
		<excerpt:encoded><![CDATA[]]></excerpt:encoded>
