{
	"theme_mods": {
		"op_popup_enable": false,
		"blog_layout": "classic",
		"container_width": 1200,
		"container_wide": 1400,
		"op_primary_color": "#1a1a1a",
		"op_accent_color": "#b8860b",
		"op_accent_hover_color": "#d4a843",
		"op_text_color": "#f5f5f5",
		"op_heading_color": "#c9a96e",
		"op_muted_color": "#999999",
		"op_header_bg": "#1a1a1a",
		"op_header_text_color": "#ffffff",
		"op_footer_bg": "#111111",
		"op_footer_text_color": "#f5f5f5",
		"op_sidebar_position": "right",
		"op_blog_excerpt_length": 55,
		"op_blog_read_more_text": "Read More",
		"op_show_breadcrumbs": true,
		"op_breadcrumb_separator": "/",
		"op_scroll_to_top": true,
		"op_dark_mode_toggle": false,
		"op_header_layout": "standard",
		"op_footer_layout": "4-cols",
		"op_blog_meta_author": true,
		"op_blog_meta_date": true,
		"op_blog_meta_categories": true,
		"op_blog_meta_tags": false,
		"op_font_heading": "Playfair Display",
		"op_font_body": "Inter",
		"op_site_layout": "full-width",
		"op_sidebar_width": 30,
		"op_blog_grid_columns": 2,
		"op_sticky_header": true,
		"op_sticky_header_on_scroll": "up",
		"op_transparent_header": false,
		"op_hero_area": true,
		"op_hero_height": "70vh",
		"op_hero_overlay": true,
		"op_shop_columns": 4,
		"op_shop_products_per_page": 12,
		"op_shop_catalog_mode": false,
		"op_quick_view": true,
		"op_variation_swatches": true,
		"op_cart_dropdown": true,
		"op_woocommerce_product_gallery_zoom": true,
		"op_woocommerce_product_gallery_lightbox": true
	},
	"options": {
		"blogname": "Opulentia Shop",
		"blogdescription": "Luxury Goods & Curated Collections",
		"posts_per_page": 10,
		"timezone_string": "America/New_York",
		"date_format": "F j, Y",
		"time_format": "g:i a",
		"woocommerce_shop_page_id": 0,
