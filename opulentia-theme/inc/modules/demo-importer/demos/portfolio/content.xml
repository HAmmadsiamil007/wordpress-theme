	<item>
		<title>About</title>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[<!-- wp:group {"style":{"spacing":{"padding":{"top":"60px","bottom":"60px"}}}} -->
		<div class="wp-block-group" style="padding-top:60px;padding-bottom:60px"><!-- wp:heading {"style":{"color":{"text":"#c9a96e"}}} -->
		<h2 class="wp-block-heading" style="color:#c9a96e">About the Studio</h2>
		<!-- /wp:heading -->

		<!-- wp:paragraph {"style":{"color":{"text":"#f5f5f5"}}} -->
		<p style="color:#f5f5f5">Opulentia Studio is a multidisciplinary creative practice based in Brooklyn, New York. We craft visual identities, digital experiences, and printed matter for brands that refuse to blend in.</p>
		<!-- /wp:paragraph -->

		<!-- wp:paragraph {"style":{"color":{"text":"#999999"}}} -->
		<p style="color:#999999">Founded in 2019, our work has been featured in Communication Arts, AIGA, and D&AD. We believe in the power of craft, the beauty of restraint, and the magic of collaboration.</p>
		<!-- /wp:paragraph --></div>
		<!-- /wp:group -->]]></content:encoded>
