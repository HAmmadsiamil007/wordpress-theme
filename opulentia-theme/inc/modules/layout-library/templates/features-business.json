g has-text-align-center has-text-color\" style=\"color:#f5f5f5\">Pixel Perfect</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"color\":{\"text\":\"#999\"}}} -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#999\">Every detail crafted with precision for a flawless visual experience across all devices.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column -->\n\n<!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:heading {\"textAlign\":\"center\",\"level\":3,\"style\":{\"color\":{\"text\":\"#f5f5f5\"}}} -->\n<h3 class=\"wp-block-heading has-text-align-center has-text-color\" style=\"color:#f5f5f5\">24/7 Support</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"color\":{\"text\":\"#999\"}}} -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#999\">Round-the-clock expert assistance to ensure your site runs smoothly at all times.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->"
