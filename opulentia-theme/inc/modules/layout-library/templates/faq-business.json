    "content": "<!-- wp:group {\"align\":\"full\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"80px\",\"bottom\":\"80px\"}}},\"backgroundColor\":\"#1a1a1a\"} -->\n<div class=\"wp-block-group alignfull has-background\" style=\"background-color:#1a1a1a;padding-top:80px;padding-bottom:80px\"><!-- wp:group {\"layout\":{\"type\":\"constrained\",\"contentSize\":\"900px\"}} -->\n<div class=\"wp-block-group\"><!-- wp:heading {\"textAlign\":\"center\",\"level\":2,\"style\":{\"color\":{\"text\":\"#c9a96e\"}}} -->\n<h2 class=\"wp-block-heading has-text-align-center has-text-color\" style=\"color:#c9a96e\">Frequently Asked Questions</h2>\n<!-- /wp:heading -->\n\n<!-- wp:spacer {\"height\":\"30px\"} -->\n<div style=\"height:30px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n<!-- /wp:spacer -->\n\n<!-- wp:group {\"className\":\"so-faq\"} -->\n<div class=\"wp-block-group so-faq\"><!-- wp:group {\"className\":\"so-faq__item\"} -->\n<div class=\"wp-block-group so-faq__item\"><!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#e8d5a3\"}}} -->\n<p class=\"has-text-color so-faq__question\" style=\"color:#e8d5a3\"><strong>How do I install the theme?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#999\"}}} -->\n<p class=\"has-text-color so-faq__answer\" style=\"color:#999\">Upload the theme ZIP via Appearance > Themes > Add New. Activate and follow the setup wizard to configure your site.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"className\":\"so-faq__item\"} -->\n<div class=\"wp-block-group so-faq__item\"><!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#e8d5a3\"}}} -->\n<p class=\"has-text-color so-faq__question\" style=\"color:#e8d5a3\"><strong>Is WooCommerce supported?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#999\"}}} -->\n<p class=\"has-text-color so-faq__answer\" style=\"color:#999\">Yes, Opulentia includes full WooCommerce template overrides, quick view, variation swatches, and a sticky add-to-cart bar.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"className\":\"so-faq__item\"} -->\n<div class=\"wp-block-group so-faq__item\"><!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#e8d5a3\"}}} -->\n<p class=\"has-text-color so-faq__question\" style=\"color:#e8d5a3\"><strong>Can I customize animations?</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#999\"}}} -->\n<p class=\"has-text-color so-faq__answer\" style=\"color:#999\">Absolutely. Go to Appearance > Customize > Animations to configure scroll reveals, parallax, and stagger effects with GSAP.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group --></div>\n<!-- /wp:group -->"
}
