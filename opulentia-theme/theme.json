{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "primary-dark",
                    "color": "#1a1a1a",
                    "name": "Primary Dark"
                },
                {
                    "slug": "secondary-dark",
                    "color": "#111111",
                    "name": "Secondary Dark"
                },
                {
                    "slug": "accent",
                    "color": "#b8860b",
                    "name": "Accent"
                },
                {
                    "slug": "gold",
                    "color": "#c9a96e",
                    "name": "Gold"
                },
                {
                    "slug": "light-gold",
                    "color": "#e8d5a3",
                    "name": "Light Gold"
                },
                {
                    "slug": "text",
                    "color": "#f5f5f5",
                    "name": "Text"
                },
                {
                    "slug": "muted",
                    "color": "#999999",
                    "name": "Muted"
                },
                {
                    "slug": "border",
                    "color": "#333333",
                    "name": "Border"
                },
                {
                    "slug": "white",
                    "color": "#ffffff",
                    "name": "White"
                }
            ],
            "gradients": [
                {
                    "slug": "gold-to-dark",
                    "gradient": "linear-gradient(135deg, #c9a96e 0%, #1a1a1a 100%)",
                    "name": "Gold to Dark"
                }
            ],
            "duotone": [
                {
                    "slug": "gold-duotone",
                    "colors": ["#1a1a1a", "#c9a96e"],
                    "name": "Gold Duotone"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "fontFamily": "\"Playfair Display\", serif",
                    "name": "Heading"
                },
                {
                    "slug": "body",
                    "fontFamily": "\"Inter\", sans-serif",
                    "name": "Body"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.875rem",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "1rem",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "1.25rem",
                    "name": "Large"
                },
                {
                    "slug": "xl",
                    "size": "1.5rem",
                    "name": "Extra Large"
                },
                {
                    "slug": "2xl",
                    "size": "2rem",
                    "name": "2X Large"
                },
                {
                    "slug": "3xl",
                    "size": "2.5rem",
                    "name": "3X Large"
                },
                {
                    "slug": "4xl",
                    "size": "3rem",
                    "name": "4X Large"
                }
            ],
            "dropCap": false
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"]
        },
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": true
                }
            },
            "core/group": {
                "spacing": {
                    "padding": true,
                    "margin": true
                }
            },
            "core/columns": {
                "spacing": {
                    "padding": true,
                    "margin": true
                }
            },
            "core/post-title": {
                "typography": {
                    "fontSize": true,
                    "lineHeight": true
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--opulentia-global-color-0)",
            "text": "var(--opulentia-global-color-5)"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--opulentia-global-color-3)"
                }
            },
            "h1": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(1.75rem, 4vw, 2.5rem)",
                    "lineHeight": "1.2"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(1.5rem, 3.5vw, 2rem)",
                    "lineHeight": "1.25"
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(1.25rem, 3vw, 1.75rem)",
                    "lineHeight": "1.3"
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(1.125rem, 2.5vw, 1.5rem)",
                    "lineHeight": "1.35"
                }
            },
            "h5": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(1rem, 2vw, 1.25rem)",
                    "lineHeight": "1.4"
                }
            },
            "h6": {
                "typography": {
                    "fontFamily": "var(--font-heading, 'Playfair Display', serif)",
                    "fontSize": "clamp(0.875rem, 1.5vw, 1rem)",
                    "lineHeight": "1.4"
                }
            },
            "button": {
                "color": {
                    "background": "var(--opulentia-global-color-2)",
                    "text": "#ffffff"
                },
                "typography": {
                    "fontFamily": "var(--font-body, 'Inter', sans-serif)",
                    "fontSize": "0.875rem"
                },
                "border": {
                    "radius": "4px"
                }
            }
        },
        "spacing": {
            "padding": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            },
            "margin": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
            }
        },
        "typography": {
            "fontFamily": "var(--font-body, 'Inter', sans-serif)",
            "fontSize": "1rem",
            "lineHeight": "1.6"
        }
    },
    "customTemplates": [
        {
            "name": "template-blank",
            "title": "Blank (No Header/Footer)",
            "postTypes": ["page", "post"]
        },
        {
            "name": "template-full-width",
            "title": "Full Width",
            "postTypes": ["page", "post"]
        }
    ],
    "templateParts": [
        {
            "area": "header",
            "name": "header"
        },
        {
            "area": "footer",
            "name": "footer"
        }
    ]
}
